<?xml version="1.0"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook
  xmlns="urn:schemas-microsoft-com:office:spreadsheet"
  xmlns:o="urn:schemas-microsoft-com:office:office"
  xmlns:x="urn:schemas-microsoft-com:office:excel"
  xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"
  xmlns:html="http://www.w3.org/TR/REC-html40">
  
    <Worksheet ss:Name="Summary">
      <Table>
        <Row><Cell><Data ss:Type="String">Metric</Data></Cell><Cell><Data ss:Type="String">Value</Data></Cell></Row><Row><Cell><Data ss:Type="String">Duplicate Title Groups</Data></Cell><Cell><Data ss:Type="String">0</Data></Cell></Row><Row><Cell><Data ss:Type="String">Duplicate Meta Description Groups</Data></Cell><Cell><Data ss:Type="String">0</Data></Cell></Row><Row><Cell><Data ss:Type="String">Duplicate Content Groups</Data></Cell><Cell><Data ss:Type="String">0</Data></Cell></Row>
      </Table>
    </Worksheet>
  
    <Worksheet ss:Name="Pages">
      <Table>
        <Row><Cell><Data ss:Type="String">URL</Data></Cell><Cell><Data ss:Type="String">Page Type</Data></Cell><Cell><Data ss:Type="String">Score</Data></Cell><Cell><Data ss:Type="String">Title</Data></Cell><Cell><Data ss:Type="String">Meta Description</Data></Cell><Cell><Data ss:Type="String">H1</Data></Cell><Cell><Data ss:Type="String">Word Count</Data></Cell><Cell><Data ss:Type="String">Issues</Data></Cell><Cell><Data ss:Type="String">Duplicate Types</Data></Cell><Cell><Data ss:Type="String">Duplicate URLs</Data></Cell></Row>
      </Table>
    </Worksheet>
  
    <Worksheet ss:Name="Duplicate Titles">
      <Table>
        <Row><Cell><Data ss:Type="String">Title</Data></Cell><Cell><Data ss:Type="String">Affected URLs</Data></Cell><Cell><Data ss:Type="String">URL Count</Data></Cell></Row><Row><Cell><Data ss:Type="String">No duplicate titles found</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">0</Data></Cell></Row>
      </Table>
    </Worksheet>
  
    <Worksheet ss:Name="Duplicate Meta">
      <Table>
        <Row><Cell><Data ss:Type="String">Meta Description</Data></Cell><Cell><Data ss:Type="String">Affected URLs</Data></Cell><Cell><Data ss:Type="String">URL Count</Data></Cell></Row><Row><Cell><Data ss:Type="String">No duplicate meta found</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">0</Data></Cell></Row>
      </Table>
    </Worksheet>
  
    <Worksheet ss:Name="Duplicate Content">
      <Table>
        <Row><Cell><Data ss:Type="String">Content Fingerprint</Data></Cell><Cell><Data ss:Type="String">Affected URLs</Data></Cell><Cell><Data ss:Type="String">URL Count</Data></Cell></Row><Row><Cell><Data ss:Type="String">No duplicate content found</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">0</Data></Cell></Row>
      </Table>
    </Worksheet>
  
</Workbook>